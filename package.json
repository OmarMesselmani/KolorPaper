{
  "name": "kolorpaper",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack && opennextjs-cloudflare build --skipNextBuild",
    "build:worker": "node scripts/build-worker-no-env-files.mjs",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:backup": "wrangler d1 export kolorpaper-d1 --remote --output=backup.sql"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-d1": "^7.8.0",
    "@prisma/adapter-mariadb": "^6.19.0",
    "@prisma/adapter-neon": "^6.19.0",
    "@prisma/client": "^6.19.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "aws4fetch": "^1.0.20",
    "bcryptjs": "^3.0.3",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.3",
    "jspdf": "^4.2.1",
    "mariadb": "^3.5.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "prisma": "^6.19.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "sanitize-html": "^2.17.4"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sanitize-html": "^2.16.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "wrangler": "^4.95.0"
  }
}
