// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  imageUrl    String?
  imageAlt    String?
  parentSlug  String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Category?      @relation("CategoryParent", fields: [parentSlug], references: [slug])
  children Category[]     @relation("CategoryParent")
  pages    ColoringPage[] @relation("CategoryPages")
  subPages ColoringPage[] @relation("SubCategoryPages")

  @@index([parentSlug])
}

model ColoringPage {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  imageUrl        String
  imageAlt        String?
  thumbnailUrl    String
  pdfUrl          String?
  categorySlug    String
  subCategorySlug String?
  description     String?
  difficulty      String? // easy, medium, hard
  ageGroup        String? // toddler, preschool, kids, adults
  style           String   @default("Cartoon") // Cartoon, Anime, Kawaii, etc.
  tags            String[] @default([])
  views           Int      @default(0)
  downloads       Int      @default(0)
  likes           Int      @default(0)
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  category    Category  @relation("CategoryPages", fields: [categorySlug], references: [slug])
  subCategory Category? @relation("SubCategoryPages", fields: [subCategorySlug], references: [slug])
  pageViews   PageView[]

  @@index([categorySlug])
  @@index([subCategorySlug])
  @@index([published])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
}

model PageView {
  id        String       @id @default(cuid())
  pageSlug  String
  action    String // "view" | "download"
  ip        String?
  userAgent String?
  createdAt DateTime     @default(now())

  page ColoringPage @relation(fields: [pageSlug], references: [slug])

  @@index([pageSlug])
  @@index([createdAt])
}

model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  date       String   // e.g. "2024-05-20"
  author     String   @default("KolorPaper Team")
  category   String
  excerpt    String
  coverImage String   // Absolute URL to cover image
  content    String   // Markdown content
  published  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([published])
}

model Tag {
  id          String   @id @default(cuid())
  name        String   @unique // The tag identifier (e.g. "rabbit")
  title       String?  // Optional custom SEO title
  description String?  // Optional custom SEO description
  h2          String?  // Optional custom H2 heading
  imageUrl    String?  // Optional image URL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
